# GEMINI_API_KEY: Server-side only key used by src/server.ts AI proxy routes.
# Do NOT expose this key to frontend bundles.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public app URL for links and callbacks.
APP_URL="https://abdullohai.sbs"

# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anonymous key (safe for frontend)
SUPABASE_ANON_KEY="your-anon-key"
